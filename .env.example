# Environment
ENVIRONMENT=development

# Domain configuration for Docker Compose
# You can add more domains by defining DOMAIN_3_NAME, DOMAIN_3_PORT, etc.
DOMAIN_1_NAME=hr
DOMAIN_1_PORT=8001

DOMAIN_2_NAME=it
DOMAIN_2_PORT=8002

# Example: Add a finance domain
# DOMAIN_3_NAME=finance
# DOMAIN_3_PORT=8003

# Embedding Service
EMBEDDING_SERVICE_PORT=8100
EMBEDDING_SERVICE_HOST=0.0.0.0

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Sentry error reporting (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# MongoDB connection
# MONGODB_URI=mongodb://localhost:27017/your_database
# MONGODB_DB_NAME=your_database

# OpenAI API configuration
# OPENAI_API_KEY=your-api-key-here
# OPENAI_API_BASE=https://api.openai.com/v1

# Other API Keys
# Add your API keys here

# Performance settings
# CACHE_TTL=300
# MAX_CACHE_SIZE=1000
# RATE_LIMIT_CALLS=100
# RATE_LIMIT_WINDOW=60